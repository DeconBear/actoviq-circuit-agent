{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://actoviq.local/schemas/layout-idiom.schema.json",
  "title": "Actoviq Layout Idiom",
  "type": "object",
  "required": ["schema", "idiom_id", "topology_tags", "lanes"],
  "properties": {
    "schema": { "const": "actoviq.layout-idiom.v1" },
    "idiom_id": { "type": "string", "minLength": 1 },
    "name": { "type": "string" },
    "topology_tags": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "module_roles": {
      "type": "array",
      "items": { "type": "string" }
    },
    "lanes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["match", "rank", "lane"],
        "properties": {
          "match": {
            "type": "object",
            "properties": {
              "type": { "type": "string" },
              "name_regex": { "type": "string" },
              "role": { "type": "string" }
            },
            "additionalProperties": false
          },
          "rank": { "type": "integer", "minimum": 0, "maximum": 16 },
          "lane": { "type": "integer", "minimum": -16, "maximum": 16 },
          "rotation": { "type": "integer", "enum": [0, 90, 180, 270] }
        },
        "additionalProperties": false
      }
    },
    "notes": { "type": "string" }
  },
  "additionalProperties": false
}
