{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://actoviq.local/schemas/vision-layout-image.schema.json",
  "title": "Actoviq Vision Layout Image Metadata",
  "type": "object",
  "required": [
    "schema",
    "ok",
    "source_path",
    "source_kind",
    "media_type",
    "width",
    "height",
    "bytes",
    "sha256",
    "rasterizer",
    "instruction"
  ],
  "properties": {
    "schema": { "const": "actoviq.vision-layout-image.v1" },
    "ok": { "const": true },
    "source_path": { "type": "string", "minLength": 1 },
    "source_kind": { "enum": ["svg", "png"] },
    "media_type": { "const": "image/png" },
    "width": { "type": "integer", "minimum": 1, "maximum": 10000 },
    "height": { "type": "integer", "minimum": 1, "maximum": 10000 },
    "bytes": { "type": "integer", "minimum": 1, "maximum": 6000000 },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "rasterizer": { "enum": ["electron", "electron-helper", "pre-rendered"] },
    "instruction": {
      "const": "Inspect the attached schematic image; propose layout-only changes and preserve connectivity."
    }
  },
  "additionalProperties": false
}
