{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://actoviq.local/schemas/layout-patch.schema.json",
  "title": "Actoviq Constrained Layout Patch",
  "type": "object",
  "required": ["schema", "operations"],
  "properties": {
    "schema": { "const": "actoviq.layout-patch.v1" },
    "operations": {
      "type": "array",
      "maxItems": 32,
      "items": {
        "oneOf": [
          { "$ref": "#/$defs/moveComponent" },
          { "$ref": "#/$defs/rotateComponent" },
          { "$ref": "#/$defs/movePort" },
          { "$ref": "#/$defs/blockPinSide" },
          { "$ref": "#/$defs/layoutLane" }
        ]
      }
    }
  },
  "$defs": {
    "gridDelta": { "type": "integer", "minimum": -6, "maximum": 6 },
    "moveComponent": { "type": "object", "required": ["op", "component_id", "dx_grid", "dy_grid"], "properties": { "op": { "const": "move_component" }, "component_id": { "type": "string" }, "dx_grid": { "$ref": "#/$defs/gridDelta" }, "dy_grid": { "$ref": "#/$defs/gridDelta" } }, "additionalProperties": false },
    "rotateComponent": { "type": "object", "required": ["op", "component_id", "rotation"], "properties": { "op": { "const": "rotate_component" }, "component_id": { "type": "string" }, "rotation": { "enum": [0, 90, 180, 270] } }, "additionalProperties": false },
    "movePort": { "type": "object", "required": ["op", "port_id", "dx_grid", "dy_grid"], "properties": { "op": { "const": "move_port" }, "port_id": { "type": "string" }, "dx_grid": { "$ref": "#/$defs/gridDelta" }, "dy_grid": { "$ref": "#/$defs/gridDelta" } }, "additionalProperties": false },
    "blockPinSide": { "type": "object", "required": ["op", "component_id", "pin_id", "side"], "properties": { "op": { "const": "set_block_pin_side" }, "component_id": { "type": "string" }, "pin_id": { "type": "string" }, "side": { "enum": ["left", "right", "top", "bottom"] } }, "additionalProperties": false },
    "layoutLane": { "type": "object", "required": ["op", "component_id", "rank", "lane"], "properties": { "op": { "const": "set_layout_lane" }, "component_id": { "type": "string" }, "rank": { "type": "integer" }, "lane": { "type": "integer" } }, "additionalProperties": false }
  },
  "additionalProperties": false
}
