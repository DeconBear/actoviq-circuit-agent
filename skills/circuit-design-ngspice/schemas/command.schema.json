{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://actoviq.local/schemas/command.schema.json",
  "title": "Actoviq Circuit Command",
  "type": "object",
  "required": ["schema", "command_id", "actor", "project_id", "base_revision", "operations"],
  "properties": {
    "schema": { "const": "actoviq.command.v1" },
    "command_id": { "type": "string", "minLength": 1 },
    "actor": { "type": "string", "minLength": 1 },
    "project_id": { "type": "string", "minLength": 1 },
    "base_revision": { "type": "integer", "minimum": 0 },
    "message": { "type": "string" },
    "operations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["op"],
        "properties": {
          "op": {
            "enum": [
              "move_module",
              "resize_module",
              "set_component_value",
              "move_component",
              "move_schematic_item",
              "reset_schematic_item",
              "connect_ports",
              "set_connection_network",
              "connect_pins",
              "upsert_module",
              "remove_module",
              "add_component",
              "remove_component",
              "add_port",
              "set_module_schematic",
              "set_module_note",
              "set_module_preview",
              "set_module_metadata"
            ]
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
